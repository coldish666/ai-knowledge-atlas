# AI Knowledge Atlas environment template.
# Copy values into backend/.env, frontend/.env, or your deployment platform as needed.
# Do not commit real secrets.

# Backend database. Leave empty to use local SQLite at data/knowledge_atlas.db.
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=

# Backend local data paths.
DATA_DIR=./data
UPLOAD_DIR=./data/uploads

# CORS origins for split frontend/backend development.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# AI provider settings. The app works with mock provider when no API key is set.
LLM_PROVIDER=mock
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

# Optional FastAPI static frontend build path for merged deployment.
FRONTEND_DIST_DIR=./frontend/dist

# Frontend API base URL.
# Local split-stack development:
VITE_API_BASE_URL=http://localhost:8000
# Production merged deployment: leave VITE_API_BASE_URL empty or unset.
