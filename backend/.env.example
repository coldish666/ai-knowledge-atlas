# Copy to backend/.env for local overrides. The app runs with mock AI by default.

# Local default uses SQLite. In cloud, set DATABASE_URL to PostgreSQL if available.
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///../data/knowledge_atlas.db

DATA_DIR=../data
UPLOAD_DIR=../data/uploads

# Comma-separated origins for split frontend/backend development or deployment.
# Same-origin merged deployment does not need CORS.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: where FastAPI should serve the built Vite app from.
FRONTEND_DIST_DIR=../frontend/dist

LLM_PROVIDER=mock
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
